@using EAgenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@using EAgenda.WebApp.Modulos.ModuloTarefa.Dominio
@{
  Layout = "_Layout";
  ViewBag.Titulo = "📝 Tarefas";
  ViewBag.Info = "Cadastre, visualize e gerencie compromissos.";
  ViewBag.TextoBotao = "Cadastrar Tarefa";
  ViewBag.ControllerBotao = "Tarefa";
  ViewBag.ActionBotao = "Cadastrar";
}

@model List<ListarTarefasViewModel>;

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
    Nenhuma tarefa cadastrada.
  </div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
    @foreach (ListarTarefasViewModel tarefa in Model)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-semibold text-dark medium">@(tarefa.Titulo)</h5>
            <hr class="my-1">
            <dl class="row g-2 mb-2 mt-2">
              <dt class="col-5 text-secondary fw-bold">Prioridade:</dt>
              <dd class="col-7 mb-0 text-break">@tarefa.Prioridade</dd>

              <dt class="col-5 text-secondary fw-bold">Data criação:</dt>
              <dd class="col-7 mb-0 text-break">@tarefa.DataCriacao.ToString("dd/MM/yyyy")</dd>
              @if (tarefa.Status == StatusConclusao.Concluida)
              {
                <dt class="col-5 text-secondary fw-bold">Data conclusão:</dt>
                <dd class="col-7 mb-0 text-break">
                  @(tarefa.DataConclusao?.ToString("dd/MM/yyyy") ?? "—")
                </dd>
              }
              <dt class="col-5 text-secondary fw-bold">Status:</dt>
              <dd class="col-7 mb-0">
                @switch (tarefa.Status)
                {
                  case StatusConclusao.Pendente:
                    <span class="badge text-bg-warning">@tarefa.Status</span>
                    break;
                  case StatusConclusao.Concluida:
                    <span class="badge text-bg-success">@tarefa.Status</span>
                    break;
                  default:
                    <span class="badge text-bg-secondary">@tarefa.Status</span>
                    break;
                }
              </dd>
              <dt class="col-5 text-secondary fw-bold">Percentual:</dt>
              <dd class="col-7 mb-0 text-break">@tarefa.PercentualConcluido%</dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
              <a asp-action="editar" asp-route-id="@tarefa.Id" class="btn btn-primary" title="Editar">
                <i class="bi bi-pencil-square"></i>
              </a>
              <a asp-action="excluir" asp-route-id="@tarefa.Id" class="btn btn-danger" title="Excluir">
                <i class="bi bi-trash"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
