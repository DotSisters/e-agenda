@using EAgenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@using EAgenda.WebApp.Modulos.ModuloTarefa.Dominio
@model ListarItensTarefaPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = "📋 Itens da Tarefa";
  ViewBag.Info = "Acompanhe o progresso da tarefa gerenciando seus itens.";
  ViewBag.TextoBotao = "Novo Item";
  ViewBag.ControllerBotao = "Tarefa";
  ViewBag.ActionBotao = "CadastrarItem";
  ViewBag.IdBotao = Model.TarefaId;
}


@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

<section class="mb-4 mt-2 d-none d-md-block">
  <div class="card border-primary-subtle shadow-sm bg-transparent">
    <div class="card-body p-0 py-3 px-4">
      <div class="d-flex flex-wrap justify-content-between gap-3">
        <div>
          <h5 class="card-title mb-1">@Model.TarefaTitulo</h5>
          <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
            @switch (Model.TarefaStatus)
            {
              case StatusConclusao.Pendente:
                <span class="badge text-bg-warning">@Model.TarefaStatus</span>
                break;
              case StatusConclusao.Concluida:
                <span class="badge text-bg-success">@Model.TarefaStatus</span>
                break;
              default:
                <span class="badge text-bg-secondary">@Model.TarefaStatus</span>
                break;
            }
            @if (Model.TarefaStatus == StatusConclusao.Concluida && Model.DataConclusao is not null)
            {
              <span class="small text-secondary">em @Model.DataConclusao.Value.ToString("dd/MM/yyyy")</span>
            }
          </div>
        </div>

        <div class="text-start text-md-end">
          <span class="text-secondary small d-block">Percentual concluído</span>
          <span class="fs-4 fw-semibold">@Model.PercentualConcluido%</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mt-2">
  <h5 class="mb-3 fw-bold">Itens</h5>

  @if (Model.Itens.Count == 0)
  {
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
      Nenhum item cadastrado nesta tarefa.
    </div>
  }
  else
  {
    <div class="list-group">
      @foreach (ItemTarefaViewModel item in Model.Itens)
      {
        <div class="list-group-item py-3 px-4">
          <div class="d-flex justify-content-between align-items-center gap-3">
            <div>
              <span class="fw-semibold d-block">@item.Titulo</span>
              @switch (item.Status)
              {
                case StatusConclusao.Pendente:
                  <span class="badge text-bg-warning mt-1">@item.Status</span>
                  break;
                case StatusConclusao.Concluida:
                  <span class="badge text-bg-success mt-1">@item.Status</span>
                  break;
                default:
                  <span class="badge text-bg-secondary mt-1">@item.Status</span>
                  break;
              }
            </div>

            <div class="d-flex align-items-center gap-2">
              @if (item.Status == StatusConclusao.Pendente)
              {
                <form asp-action="ConcluirItem" method="post" class="d-inline">
                  <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                  <input type="hidden" name="itemId" value="@item.Id" />
                  <button type="submit" class="btn btn-success btn-sm" title="Concluir">
                    <i class="bi bi-check-lg"></i>
                  </button>
                </form>
              }
              else
              {
                <form asp-action="ReabrirItem" method="post" class="d-inline">
                  <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                  <input type="hidden" name="itemId" value="@item.Id" />
                  <button type="submit" class="btn btn-warning btn-sm" title="Reabrir">
                    <i class="bi bi-arrow-counterclockwise"></i>
                  </button>
                </form>
              }

              <form asp-action="RemoverItem" method="post" class="d-inline">
                <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                <input type="hidden" name="itemId" value="@item.Id" />
                <button type="submit" class="btn btn-danger btn-sm" title="Remover">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      }
    </div>
  }
</section>
