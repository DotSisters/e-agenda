@using EAgenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@using EAgenda.WebApp.Modulos.ModuloTarefa.Dominio
@model ListarItensTarefaPaginaViewModel
@{
  Layout = "_Layout";
  ViewBag.Titulo = "📋 Itens da Tarefa";
  ViewBag.Info = $"Gerencie os itens da tarefa \"{Model.TarefaTitulo}\".";
}

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

<div class="card border-primary-subtle shadow-sm mx-auto mb-4 p-4 bg-transparent" style="max-width: 720px;">
  <h5 class="fw-semibold text-dark mb-3">@Model.TarefaTitulo</h5>
  <dl class="row g-2 mb-0">
    <dt class="col-4 text-secondary fw-bold">Status:</dt>
    <dd class="col-8 mb-0">
      @switch (Model.TarefaStatus)
      {
        case StatusConclusao.Pendente:
          <span class="badge text-bg-warning">@Model.TarefaStatus</span>
          break;
        case StatusConclusao.Concluida:
          <span class="badge text-bg-success">@Model.TarefaStatus</span>
          break;
        default:
          <span class="badge text-bg-secondary">@Model.TarefaStatus</span>
          break;
      }
    </dd>

    <dt class="col-4 text-secondary fw-bold">Percentual:</dt>
    <dd class="col-8 mb-0">@Model.PercentualConcluido%</dd>

    @if (Model.TarefaStatus == StatusConclusao.Concluida)
    {
      <dt class="col-4 text-secondary fw-bold">Data conclusão:</dt>
      <dd class="col-8 mb-0">@(Model.DataConclusao?.ToString("dd/MM/yyyy") ?? "—")</dd>
    }
  </dl>
</div>

@if (Model.Itens.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 720px;" role="alert">
    Nenhum item cadastrado nesta tarefa.
  </div>
}
else
{
  <div class="row row-cols-1 g-2 mx-auto" style="max-width: 720px;">
    @foreach (ItemTarefaViewModel item in Model.Itens)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
            <div>
              <h6 class="card-title fw-semibold text-dark mb-1">@item.Titulo</h6>
              @switch (item.Status)
              {
                case StatusConclusao.Pendente:
                  <span class="badge text-bg-warning">@item.Status</span>
                  break;
                case StatusConclusao.Concluida:
                  <span class="badge text-bg-success">@item.Status</span>
                  break;
                default:
                  <span class="badge text-bg-secondary">@item.Status</span>
                  break;
              }
            </div>

            <div class="d-flex flex-wrap gap-2">
              @if (item.Status == StatusConclusao.Pendente)
              {
                <form asp-action="ConcluirItem" method="post" class="d-inline">
                  <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                  <input type="hidden" name="itemId" value="@item.Id" />
                  <button type="submit" class="btn btn-success" title="Concluir">
                    <i class="bi bi-check-lg"></i>
                  </button>
                </form>
              }
              else
              {
                <form asp-action="ReabrirItem" method="post" class="d-inline">
                  <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                  <input type="hidden" name="itemId" value="@item.Id" />
                  <button type="submit" class="btn btn-warning" title="Reabrir">
                    <i class="bi bi-arrow-counterclockwise"></i>
                  </button>
                </form>
              }

              <form asp-action="RemoverItem" method="post" class="d-inline">
                <input type="hidden" name="tarefaId" value="@Model.TarefaId" />
                <input type="hidden" name="itemId" value="@item.Id" />
                <button type="submit" class="btn btn-danger" title="Remover">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

<form class="card border-primary-subtle shadow-sm mx-auto mt-4 p-4 bg-transparent" style="max-width: 720px;"
  asp-action="AdicionarItem" method="post">
  <input type="hidden" asp-for="NovoItem.TarefaId" />

  <h6 class="fw-semibold text-primary text-uppercase small mb-3">Adicionar Item</h6>

  <div class="mb-3">
    <label asp-for="NovoItem.Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
    <input asp-for="NovoItem.Titulo" type="text" class="form-control">
    <span asp-validation-for="NovoItem.Titulo" class="text-danger small fw-semibold"></span>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <a class="btn btn-outline-primary rounded-2 px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-2 px-4" type="submit">Adicionar</button>
  </div>
</form>
