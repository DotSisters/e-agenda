@using EAgenda.WebApp.Modulos.ModuloTarefa.Apresentacao
@{
  Layout = "_Layout";
  ViewBag.Titulo = "🗑️ Excluir Tarefa";
  ViewBag.Info = "Confirme a exclusão desta tarefa.";
}

@model ExcluirTarefaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
      asp-action="Excluir" asp-route-id="@Model.Id" method="post">
  <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
    Deseja realmente excluir esta tarefa?
  </div>

  <div class="mb-3">
    <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
    <input asp-for="Titulo" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small">Prioridadel</label>
    <input asp-for="Prioridade" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="Status" class="form-label fw-semibold text-primary text-uppercase small">Status</label>
    <input asp-for="Status" type="text" class="form-control" disabled>
  </div>

  <div class="mb-3">
    <label asp-for="PercentualConcluido"
           class="form-label fw-semibold text-primary text-uppercase small">Percentual</label>
    <input asp-for="PercentualConcluido" type="text" class="form-control" disabled>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-secondary rounded-2 px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-2 px-4" type="submit">Confirmar</button>
  </div>
</form>
