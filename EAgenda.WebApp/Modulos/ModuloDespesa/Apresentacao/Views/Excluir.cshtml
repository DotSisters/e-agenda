@using EAgenda.WebApp.Modulos.ModuloDespesa.Dominio

@{
Layout = "_Layout";
ViewBag.Titulo = "🗑️ Excluir Despesa";
ViewBag.Info = "Confirme a exclusão desta despesa.";
}

@model ExcluirDespesaViewModels;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
    asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
        Deseja realmente excluir esta despesa?
    </div>

    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descrição</label>
        <input asp-for="Descricao" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Data</label>
        <input type="text" class="form-control" value="@Model.Ocorrencia.ToString(" dd/MM/yyyy")" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Valor" class="form-label fw-semibold text-primary text-uppercase small">Valor</label>
        <input asp-for="Valor" type="text" class="form-control" disabled>
    </div>

    @{
    string pagamentoTexto = Model.Pagamento switch
    {
    FormaPagamento.AVista => "À Vista",
    FormaPagamento.Credito => "Crédito",
    FormaPagamento.Debito => "Débito",
    _ => Model.Pagamento.ToString()
    };
    }

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Pagamento</label>
        <input type="text" class="form-control" value="@pagamentoTexto" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
        <input type="text" class="form-control" value="@Model.CategoriaNome" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>