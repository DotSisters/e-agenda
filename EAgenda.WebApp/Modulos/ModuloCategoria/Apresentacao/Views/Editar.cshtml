        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título da
            Categoria</label>
        <input asp-for="Titulo" type="text" class="form-control">
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

