@{
Layout = "_Layout";
ViewBag.Titulo = "🗑️ Excluir Contato";
ViewBag.Info = "Confirme a exclusão deste contato.";
}

@model ExcluirContatoViewModels;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
    asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
        Deseja realmente excluir este contato?
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-primary text-uppercase small">E-mail</label>
        <input asp-for="Email" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label fw-semibold text-primary text-uppercase small">Telefone</label>
        <input asp-for="Telefone" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Cargo" class="form-label fw-semibold text-primary text-uppercase small">Cargo</label>
        <input asp-for="Cargo" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Empresa" class="form-label fw-semibold text-primary text-uppercase small">Empresa</label>
        <input asp-for="Empresa" type="text" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>